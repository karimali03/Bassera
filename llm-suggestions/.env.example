# ── OpenRouter ───────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_MAX_TOKENS=8192
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=http://localhost:8000
OPENROUTER_APP_NAME=Baseera LLM Suggestions Service

# ── Service ──────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# ── Security ─────────────────────────────────────────────────────────────────
# Simple API key auth for the hackathon — replace with OAuth in production
SERVICE_API_KEY=change-me-before-deploy
# When true, the OpenRouter key may be used as the local SERVICE_API_KEY (development only)
ALLOW_SHARED_API_KEY=false

# ── Rate limiting (requests/minute per client) ───────────────────────────────
RATE_LIMIT_RPM=30
